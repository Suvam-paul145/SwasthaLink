# ===============================
# SwasthaLink Frontend Environment
# File: /.env (project root)
# ===============================

# REQUIRED
# Backend API base URL used by frontend (src/utils/config.js)
VITE_API_URL=http://localhost:8000

# Backend Groq chatbot configuration
# Used by the patient chatbot route on the FastAPI server.
GROQ_API_KEY=your_groq_api_key_here
# Optional override for the backend chatbot model
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Backend prescription/document extraction
# Preferred over Gemini for prescription upload OCR + structured extraction.
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# NOTE
# The following variables are NOT currently used in frontend code.
# Keep them commented unless you implement corresponding features.

# Optional (not currently used)
# VITE_SENTRY_DSN=your_sentry_dsn_here

# Optional feature flags (not currently used)
# VITE_ENABLE_FILE_UPLOAD=true
# VITE_ENABLE_ANALYTICS=true

# Demo mode — set to false to disable mock data for demo emails
VITE_ENABLE_DEMO=true
