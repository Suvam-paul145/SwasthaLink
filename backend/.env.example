# =====================================
# SwasthaLink Backend Environment (.env)
# File: /backend/.env
# =====================================

# REQUIRED: Groq API (core conversational AI processing)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# REQUIRED: Qwen Coder Cloud Model (RAG and structural extraction)
# (Compatible with OpenRouter, Together AI, custom Ollama base, etc.)
QWEN_API_KEY=your_qwen_api_key_here
# Optional: defaults to OpenRouter if not specified
QWEN_BASE_URL=https://openrouter.ai/api/v1
# The identifier of the Qwen Coder model to use
QWEN_MODEL_NAME=qwen/qwen-2.5-coder-32b-instruct

# REQUIRED: Twilio WhatsApp API (message delivery)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# Optional (has default): Twilio sandbox sender number
# Default in code: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# REQUIRED: Supabase API (session metadata logging, no PHI)
# Get from: Supabase Project -> Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Auth mode:
# false (default) -> use Supabase Auth (auth.users) + optional profiles table
# true            -> disable Supabase Auth, use only profiles table credentials
DISABLE_SUPABASE_AUTH=false

# Password hash iterations for DB-only auth mode (PBKDF2-SHA256)
AUTH_PASSWORD_HASH_ITERATIONS=390000

# Forgot-password reset session expiry in minutes
AUTH_PASSWORD_RESET_TOKEN_MINUTES=15

# Persistent history behavior (set true to always store full clinical history in DB)
STORE_FULL_HISTORY=true

# OPTIONAL: AWS S3 API (needed only for /api/upload file upload feature)
# If you do not use uploads, you can leave these empty.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=discharge-uploads-yourname

# App runtime configuration
# Set this to your frontend URL for CORS in production
FRONTEND_URL=https://swasthalink.vercel.app
ENVIRONMENT=development
DEBUG=false
PORT=8000

# Optional monitoring (not currently used in backend code)
SENTRY_DSN=your_sentry_dsn_here

# =====================================
# Proactive Rate Alert Configuration
# =====================================
# Enables in-app usage tracking + pre-limit alerting
RATE_ALERTS_ENABLED=true
RATE_ALERT_THRESHOLD_PERCENT=80

# LLM pre-limit guard (request is blocked *before* next call would cross threshold)
# Thresholds accept either percent (80, 95) or fraction (0.8, 0.95)
LLM_RPM_LIMIT=15
LLM_RPD_LIMIT=1500
LLM_RATE_WARNING_THRESHOLD=80
LLM_RATE_BLOCK_THRESHOLD=95

# Configure these to your real daily provider limits
RATE_ALERT_LLM_DAILY_LIMIT=1000
RATE_ALERT_TWILIO_DAILY_LIMIT=500
RATE_ALERT_SUPABASE_DAILY_LIMIT=5000
RATE_ALERT_S3_DAILY_LIMIT=1000

# Email alert channel (SMTP)
RATE_ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_app_password
SMTP_USE_TLS=true
ALERT_FROM_EMAIL=your_email@example.com
ALERT_TO_EMAIL=your_email@example.com

# GitHub alert channel (creates issue -> GitHub notification)
RATE_ALERT_GITHUB_ENABLED=false
GITHUB_TOKEN=your_github_pat_with_repo_scope
GITHUB_REPO_OWNER=Suvam-paul145
GITHUB_REPO_NAME=SwasthaLink
