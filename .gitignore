# =============================================================================
# SwasthaLink .gitignore
# Stack: Vite + React (frontend) | FastAPI + Python (backend) | Docker | Supabase
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS & ENVIRONMENT VARIABLES — NEVER COMMIT
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
reference-file/security-credential/

# -----------------------------------------------------------------------------
# NODE / FRONTEND
# -----------------------------------------------------------------------------
node_modules/
*/node_modules/
dist/
.vite/
vite.config.js.timestamp-*

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Parcel cache
.cache/
.parcel-cache/

# -----------------------------------------------------------------------------
# PYTHON / BACKEND
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
.venv/
env/
ENV/
.env/
pip-log.txt
pip-delete-this-directory.txt

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# mypy / pyright type cache
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
pyrightconfig.json

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# TESTING
# -----------------------------------------------------------------------------
.pytest_cache/
.tox/
.nox/
coverage/
.nyc_output/
test-results/
junit.xml

# -----------------------------------------------------------------------------
# DATABASE FILES
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
SwasthaLink.db
backend/SwasthaLink.db

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
.dockerignore.local

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
logs/
*.log
backend/logs/

# -----------------------------------------------------------------------------
# UPLOADS / MEDIA (local test files only — allow tracked sample data)
# -----------------------------------------------------------------------------
uploads/
*.pdf
*.jpg
*.jpeg
*.png
*.gif
*.webp
!sample_data/*.pdf
!sample_data/*.txt
!sample-data/*.md

# -----------------------------------------------------------------------------
# OS & EDITOR ARTIFACTS
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# JetBrains IDEs
.idea/
*.iml
*.ipr
*.iws

# VS Code (keep shared settings if desired; ignore personal/local overrides)
.vscode/launch.json
.vscode/*.local.*

# Vim / Emacs
*.swp
*.swo
*.bak
\#*\#
.#*

# -----------------------------------------------------------------------------
# TEMPORARY & MISC
# -----------------------------------------------------------------------------
*.tmp
*.temp
tmp/
temp/
.cache/
.claude
.aider*
*.orig

# Reference files — local only
reference-file/

